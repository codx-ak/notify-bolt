{
  "name": "notify-bold",
  "version": "1.0.0",
  "description": "A React package for custom alerts and toast notifications.",
  "author": "Ak Moorthi",
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.esm.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rollup -c --bundleConfigAsCjs",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "typescript": "^5.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rollup": "^4.40.0",
    "postcss": "^8.5.3",
    "tslib": "^2.8.1"
  },
  "keywords": [
    "react",
    "react-alert",
    "react-toast",
    "react-notification",
    "alert",
    "toast",
    "react-smart-modal",
    "notify",
    "notify-bold",
    "notification",
    "bold",
    "custom-alerts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/codx-ak/notify-bolt.git"
  },
  "bugs": {
    "url": "https://github.com/codx-ak/notify-bolt/issues"
  },
  "homepage": "https://github.com/codx-ak/notify-bolt#readme",
  "publishConfig": {
    "access": "public"
  }
}
